{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Debug Estacionamento.WebApi",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-webapi",
      "program": "${workspaceFolder}/Estacionamento.WebApi/bin/Debug/net8.0/Estacionamento.WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Estacionamento.WebApi",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5215"
      }
    }
  ]
}
